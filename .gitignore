# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# --- Data mentah & hasil (JANGAN di-commit; digenerate ulang di Kaggle) ---
data/raw/*
!data/raw/.gitkeep
data/splits/*
!data/splits/.gitkeep

outputs/predictions/*
outputs/figures/*
outputs/checkpoints/*
outputs/logs/*
# outputs/results/ SENGAJA DIKECUALIKAN dari ignore di bawah (ditrack di git) —
# berisi ringkasan hasil akhir (final_table.csv, significance.json, dll), bukan
# artefak besar, dan berguna untuk membandingkan riwayat eksperimen antar commit.
# pertahankan struktur folder-nya saja untuk yang lain
!outputs/**/.gitkeep
# Figure kalibrasi hasil analisis mendalam: kecil (<100KB) & penting utk laporan -> ditrack.
!outputs/figures/calibration_*.png
# Figure diagnostik TTA (Fig. 1 paper): kecil & penting, regenerate via scripts/make_fig1.py.
!outputs/figures/fig1_*.png

# --- Model / artefak besar ---
*.pt
*.ckpt
*.npy
*.pkl
*.h5
outputs/*.zip
hasil_outputs.zip

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Dokumen peneliti (draft paper, audit, log) — LOKAL saja, tidak di-push ---
docs/
trash/
